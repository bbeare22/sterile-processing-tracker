# Server
PORT=3001
CLIENT_URL=http://localhost:5173

# Database
MONGO_URI=your-mongo-uri

# Auth
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# Email (optional; if absent, mails are logged to console)
SMTP_HOST=
SMTP_PORT=25
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
ALERT_FROM=no-reply@example.com
ALERT_TO=you@example.com

# Reminder scheduler (optional)
CRON_TZ=America/Denver
CRON_HOUR=8
CRON_MINUTE=0

